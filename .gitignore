.idea/
.vscode/
*.iml

# ── Misc / secrets (never commit) ───────────────────────────────
*.log
.env
# Deployment credentials (PAT / signing / endpoints) — never commit. `.env` above
# won't match `deploy.env`, so list it (and any `deploy.env.<stage>`) explicitly.
deploy.env
deploy.env.*
secrets.*
android/local.properties
android/keystore.properties
android/noop-release.jks

# ── Personal data — NEVER publish (real WHOOP/Apple Health exports) ──
Fixtures/
*.sqlite
*.sqlite-wal
*.sqlite-shm
export.xml
export.zip
*whoop_export*.zip
*apple_health*.zip

# Deliberate exception (Phase 2a Task 8): the committed backup-restore test fixture. SYNTHETIC
# demo data only (generated by a fresh :app:installDemoDebug + DemoSeeder run, never real user
# data), trimmed to the most recent 21 days by Tools/make-backup-fixture.sh. The `Fixtures/` rule
# above matches this dir case-insensitively on macOS.
!shared/src/commonTest/fixtures/
!shared/src/commonTest/fixtures/noopbak-demo-v17-mini.zip
# Deliberate exception (Phase 2c-1 Task 2): the committed GRDB-to-Room ETL test fixture.
# SYNTHETIC formulaic data only, generated deterministically by Tools/make-grdb-fixture.sh
# (fixed epoch base, recursive CTEs, no real user data); overrides the `*.sqlite` rule above.
!shared/src/commonTest/fixtures/grdb-mini.sqlite

# Deliberate exception (#65 T1): the frozen legacy-GRDB schema fixture for WhoopStore tests.
# SYNTHETIC — schema-only dump plus one hand-written "my-whoop" pairedDevice row (no MAC,
# serial, or biometric data); overrides the `Fixtures/` and `*.sqlite` rules above. CI needs
# these files to build the WhoopStoreTests resource bundle (Bundle.module).
!Packages/WhoopStore/Tests/WhoopStoreTests/Fixtures/
!Packages/WhoopStore/Tests/WhoopStoreTests/Fixtures/*.sql
!Packages/WhoopStore/Tests/WhoopStoreTests/Fixtures/*.sqlite

# Python bytecode
__pycache__/
*.pyc

# Local release artifacts (zips/ipas built for upload; never tracked)
dist/
err.txt

# ── Gradle (root KMP build; android/ has its own .gitignore) ───
.gradle/
local.properties
